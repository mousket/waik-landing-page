# ===========================================
# Environment Variables Configuration
# ===========================================
# Copy this file to .env and fill in your values
# Never commit .env to version control

# ===========================================
# Server Configuration
# ===========================================

# Node Environment (development | production)
NODE_ENV=production

# Server Port (cPanel usually sets this automatically via PORT env var)
# Default: 3000
PORT=3000

# Server Hostname (OPTIONAL - only set if needed)
# - Leave unset: Auto-detects (localhost for dev, 0.0.0.0 for production)
# - '0.0.0.0': Bind to all network interfaces (for cPanel reverse proxy)
# - Specific IP: Use if your hosting provider requires a specific IP
# For most cPanel deployments, you can leave this unset
# HOSTNAME=0.0.0.0

# ===========================================
# Application URLs
# ===========================================

# Production Site URL (REQUIRED for production)
# Set this to your production domain for proper URL generation
NEXT_PUBLIC_SITE_URL=https://waik.care

# ===========================================
# Database Configuration
# ===========================================

# MongoDB Connection String (if using MongoDB)
# Format: mongodb://[username:password@]host[:port][/database][?options]
DATABASE_URL=your_mongodb_connection_string_here
MONGO_DB_CONNECTION_STRING

# MongoDB Database Name (optional, defaults to 'waik-demo')
MONGODB_DB_NAME=waik-demo

# ===========================================
# OpenAI Configuration
# ===========================================

# OpenAI API Key (REQUIRED for AI features)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_api_key_here

# OpenAI LLM Model (optional, defaults to 'gpt-4o-mini')
OPENAI_LLM_MODEL=gpt-4o-mini

# OpenAI Embedding Model (optional, defaults to 'text-embedding-3-small')
OPENAI_TEXT_EMBEDDING_MODEL=text-embedding-3-small

# ===========================================
# cPanel Deployment Notes
# ===========================================
# For cPanel deployment:
# 1. Set NODE_ENV=production
# 2. Set NEXT_PUBLIC_SITE_URL=https://waik.care
# 3. PORT is usually set automatically by cPanel
# 4. HOSTNAME can usually be left unset (defaults to 0.0.0.0 in production)
# 5. Add your DATABASE_URL and OPENAI_API_KEY values


# ===========================================
# MongoDB Configuration (if using MongoDB for database)
# ===========================================
#starts with mongodb+srv:// (or mongodb+srv:// for production)
MONGO_DB_USER=waik_db_admin
MONGO_DB_PASSWORD=we8z5PJMNs96xTHp
MONGO_DB_CONNECTION_STRING=mongodb+srv://waik_db_admin:we8z5PJMNs96xTHp@waik.jzkd1s8.mongodb.net/?appName=waik
DATABASE_URL=mongodb+srv://waik_db_admin:we8z5PJMNs96xTHp@waik.jzkd1s8.mongodb.net/?appName=waik




