# ===========================================
# REDIS (Expert Investigator session store — task-03a)
# ===========================================
# Option A: single URL (encode special characters in the password)
# REDIS_URL=redis://user:password@host:port
# Option B: host + WAiK dev ACL user (used by lib/redis.ts when REDIS_URL is unset)
# REDIS_HOST=your-redis.example.com:12345
# WAIK_REDIS_USER=your_redis_username
# WAIK_REDIS_USER_PASSWORD=your_password
# Optional: numeric DB index (default 0). REDIS_WAIK_DATABASE is a label unless it is digits.
# REDIS_DB=0
# REDIS_USE_TLS=1

# ===========================================
# WAiK product telemetry (Phase 3e — super-admin admin entry, optional HTTP sink)
# ===========================================
# Every event is logged server-side as: [WAiK_TELEMETRY] {"type":"..."}
# Optional: forward the same JSON line to an HTTPS endpoint (Datadog, custom ingest, etc.).
# Leave WAIK_TELEMETRY_HTTP_URL unset to use console only.
# WAIK_TELEMETRY_HTTP_URL=https://http-intake.logs.example.com/v1/ingest
# Optional bearer for the sink (e.g. API key as Bearer)
# WAIK_TELEMETRY_HTTP_BEARER_TOKEN=
# Or a custom header (e.g. some vendors use X-API-Key) — do not set both bearer and these if your vendor needs only one.
# WAIK_TELEMETRY_HTTP_HEADER_NAME=
# WAIK_TELEMETRY_HTTP_HEADER_VALUE=
